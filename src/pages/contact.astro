---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config';

const channels = [
  { label: 'Email', value: site.email, href: site.email ? `mailto:${site.email}` : '' },
  { label: 'GitHub', value: site.social.github, href: site.social.github },
  { label: 'Bilibili', value: site.social.bilibili, href: site.social.bilibili },
  { label: '知乎', value: site.social.zhihu, href: site.social.zhihu },
]
  .filter((c) => c.href)
  .map((c) => ({
    ...c,
    value: c.value.replace(/^https?:\/\//, ''),
  }));
---

<BaseLayout title="联系" description="通过邮箱或社交账号联系我。">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="font-mono text-sm text-accent mb-4">$ ./contact.sh</p>
    <h1 class="text-4xl font-bold mb-3">联系我</h1>
    <p class="text-ink-dim mb-12">有想法、机会或只是想聊聊嵌入式？欢迎找我。</p>

    <div class="space-y-3">
      {channels.map((c) => (
        <a
          href={c.href}
          target="_blank"
          rel="noopener noreferrer"
          class="card p-5 flex items-center justify-between group"
        >
          <span class="font-mono text-sm text-ink-dim">{c.label}</span>
          <span class="text-ink group-hover:text-accent transition-colors">{c.value}</span>
        </a>
      ))}
    </div>

    <p class="mt-10 text-sm text-ink-faint">
      提示：把 <code class="font-mono text-accent">src/config.ts</code> 里的邮箱和社交链接换成你自己的就行。
    </p>
  </section>
</BaseLayout>
