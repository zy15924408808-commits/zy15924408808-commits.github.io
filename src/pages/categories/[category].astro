---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { postUrl, fmtDate, postCategory } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const cats = new Set<string>();
  posts.forEach((p) => cats.add(postCategory(p)));

  return [...cats].map((category) => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter((p) => postCategory(p) === category)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={category} description={`分类「${category}」下的全部文章。`}>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <a href="/categories" class="font-mono text-sm text-ink-dim hover:text-accent transition-colors">← 全部分类</a>
    <h1 class="text-4xl font-bold mt-6 mb-3">
      <span class="font-mono text-accent">▸</span> {category}
    </h1>
    <p class="text-ink-dim mb-12">共 {posts.length} 篇文章。</p>

    <ul class="divide-y divide-line">
      {posts.map((post) => (
        <li>
          <a href={postUrl(post)} class="group block py-4">
            <div class="flex items-baseline justify-between gap-4">
              <span class="text-ink group-hover:text-accent transition-colors font-medium">{post.data.title}</span>
              <span class="font-mono text-xs text-ink-faint whitespace-nowrap">{fmtDate(post.data.date)}</span>
            </div>
            {post.data.description && (
              <p class="mt-1 text-sm text-ink-dim leading-relaxed">{post.data.description}</p>
            )}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
