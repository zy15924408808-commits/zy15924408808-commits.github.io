---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { groupByCategory } from '../../utils/blog';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const categories = groupByCategory(posts);
---

<BaseLayout title="分类" description="按分类浏览全部文章。">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="font-mono text-sm text-accent mb-4">$ classify</p>
    <h1 class="text-4xl font-bold mb-3">分类</h1>
    <p class="text-ink-dim mb-12">点击查看该分类下的全部文章。</p>

    {categories.length === 0 ? (
      <p class="text-ink-dim">还没有文章。在 <code class="font-mono text-accent">src/content/blog/</code> 下建子文件夹（如「嵌入式」）再放文章即可。</p>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2">
        {categories.map(([cat, catPosts]) => (
          <a href={`/categories/${cat}`} class="card p-5 group">
            <div class="flex items-center justify-between">
              <h2 class="text-lg font-semibold text-ink group-hover:text-accent transition-colors">{cat}</h2>
              <span class="font-mono text-xs text-ink-faint">{catPosts.length} 篇</span>
            </div>
            <p class="mt-2 text-sm text-ink-dim truncate">
              {catPosts.map((p) => p.data.title).join(' · ')}
            </p>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
