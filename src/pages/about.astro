---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config';
import { getCollection } from 'astro:content';

// 技能栈 —— 按你的实际情况改这里
const skills = [
  { group: '编程语言', items: ['C', 'C++', 'Python', '汇编'] },
  { group: '单片机 / 平台', items: ['STM32', '51 单片机', 'ESP32'] },
  { group: '系统 / 框架', items: ['FreeRTOS', 'Linux', 'HAL 库'] },
  { group: '工具', items: ['Keil', 'CubeMX', 'Git', '示波器/逻辑分析仪'] },
];

// 时间线 —— 按你的实际经历改这里
const timeline = [
  { time: '2025 — 至今', title: '大学二年级', desc: '系统学习嵌入式开发，深入单片机与 RTOS。' },
  { time: '2024', title: '大学一年级', desc: '打下 C 语言与电子电路基础，第一次接触单片机。' },
];

// 荣誉证书 —— 从 src/content/awards/ 读取，按 order 再按时间倒序
const awards = (await getCollection('awards')).sort((a, b) => {
  const oa = a.data.order ?? 999;
  const ob = b.data.order ?? 999;
  if (oa !== ob) return oa - ob;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

const fmtYM = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
---

<BaseLayout title="关于" description="关于我，我的背景、技能与学习经历。">
  <section class="mx-auto max-w-3xl px-6 py-16">
    <p class="font-mono text-sm text-accent mb-4">$ cat about.md</p>
    <h1 class="text-4xl font-bold mb-8">关于我</h1>

    <div class="prose-tech text-lg">
      <p>
        我是一名大二在读学生，目前正专注于<strong>嵌入式系统开发</strong>的学习，
        希望未来从事嵌入式相关的工作。我喜欢和硬件打交道，享受代码真实地驱动一颗芯片、
        点亮一盏灯、转动一个电机的那种掌控感。
      </p>
      <p>
        这个网站用来记录我的项目、学习笔记和成长轨迹。
        （这段文字是占位内容，你可以随时替换成自己的介绍。）
      </p>
    </div>

    {site.resume && (
      <a
        href={`/${site.resume}`}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-bg shadow-glow hover:bg-accent-glow transition-colors"
      >
        <span>↓</span> 下载简历 PDF
      </a>
    )}

    <!-- 技能 -->
    <h2 class="text-2xl font-bold mt-14 mb-6">
      <span class="font-mono text-accent text-base mr-2">#</span>技能栈
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {skills.map((s) => (
        <div class="card p-5">
          <h3 class="text-sm font-semibold text-ink-dim mb-3">{s.group}</h3>
          <div class="flex flex-wrap gap-2">
            {s.items.map((i) => (
              <span class="font-mono text-xs text-accent/90 bg-accent/5 border border-accent/20 rounded px-2 py-1">{i}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 时间线 -->
    <h2 class="text-2xl font-bold mt-14 mb-6">
      <span class="font-mono text-accent text-base mr-2">#</span>经历
    </h2>
    <ol class="relative border-l border-line ml-2">
      {timeline.map((t) => (
        <li class="ml-6 pb-8 last:pb-0">
          <span class="absolute -left-[5px] mt-1.5 h-2.5 w-2.5 rounded-full bg-accent shadow-glow-sm"></span>
          <p class="font-mono text-xs text-accent">{t.time}</p>
          <h3 class="text-lg font-semibold text-ink mt-1">{t.title}</h3>
          <p class="text-sm text-ink-dim mt-1 leading-relaxed">{t.desc}</p>
        </li>
      ))}
    </ol>

    <!-- 荣誉证书 -->
    {awards.length > 0 && (
      <>
        <h2 class="text-2xl font-bold mt-14 mb-6">
          <span class="font-mono text-accent text-base mr-2">#</span>荣誉证书
        </h2>
        <div class="grid gap-5 sm:grid-cols-2">
          {awards.map((a) => (
            <div class="card overflow-hidden flex flex-col">
              {a.data.image && (
                <button
                  type="button"
                  class="cert-thumb block w-full aspect-[4/3] bg-bg-soft overflow-hidden"
                  data-src={`/certs/${a.data.image}`}
                  data-title={a.data.title}
                >
                  <img
                    src={`/certs/${a.data.image}`}
                    alt={a.data.title}
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                  />
                </button>
              )}
              <div class="p-4">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="text-sm font-semibold text-ink leading-snug">{a.data.title}</h3>
                  {a.data.level && (
                    <span class="shrink-0 font-mono text-[11px] text-accent bg-accent/10 border border-accent/30 rounded px-1.5 py-0.5">{a.data.level}</span>
                  )}
                </div>
                <p class="mt-2 font-mono text-xs text-ink-faint">
                  {a.data.issuer && <span>{a.data.issuer} · </span>}{fmtYM(a.data.date)}
                </p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </section>

  <!-- 证书放大预览 -->
  <div id="cert-lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/85 backdrop-blur-sm p-6 cursor-zoom-out">
    <figure class="max-w-4xl max-h-[90vh] flex flex-col items-center">
      <img id="cert-lightbox-img" src="" alt="" class="max-h-[80vh] w-auto rounded-lg border border-line shadow-glow" />
      <figcaption id="cert-lightbox-cap" class="mt-4 text-sm text-ink-dim font-mono"></figcaption>
    </figure>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const box = document.getElementById('cert-lightbox');
      const img = document.getElementById('cert-lightbox-img');
      const cap = document.getElementById('cert-lightbox-cap');
      if (!box) return;

      document.querySelectorAll('.cert-thumb').forEach((btn) => {
        btn.addEventListener('click', () => {
          img.src = btn.getAttribute('data-src');
          img.alt = btn.getAttribute('data-title') || '';
          cap.textContent = btn.getAttribute('data-title') || '';
          box.classList.remove('hidden');
          box.classList.add('flex');
          document.body.style.overflow = 'hidden';
        });
      });

      const close = () => {
        box.classList.add('hidden');
        box.classList.remove('flex');
        document.body.style.overflow = '';
      };
      box.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    });
  </script>
</BaseLayout>
