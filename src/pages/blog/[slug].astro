---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comments from '../../components/Comments.astro';
import { getCollection } from 'astro:content';
import { postSlug, postUrl, postCategory } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );

  // 网址用扁平 slug（只取文件名）。检查不同文件夹里是否有同名文件导致冲突。
  const seen = new Map<string, string>();
  for (const p of posts) {
    const s = postSlug(p);
    if (seen.has(s)) {
      throw new Error(
        `博客文章 slug 冲突："${s}" 同时出现在 ${seen.get(s)} 和 ${p.slug}。请给其中一个文件改名（网址按文件名生成，不能重名）。`
      );
    }
    seen.set(s, p.slug);
  }

  return posts.map((post, i) => ({
    params: { slug: postSlug(post) },
    props: {
      post,
      // 列表已按时间倒序：上一篇=更新的，下一篇=更早的
      newer: posts[i - 1] ?? null,
      older: posts[i + 1] ?? null,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { Content, headings } = await post.render();
const { title, date, description, tags } = post.data;
const category = postCategory(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });

// 估算阅读时长：按每分钟 350 字（中文）
const words = post.body.replace(/\s/g, '').length;
const readMins = Math.max(1, Math.round(words / 350));

// 只取 h2/h3 作为目录
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description ?? title}>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:flex lg:gap-10">
    <article class="min-w-0 flex-1 max-w-3xl mx-auto">
      <a href="/blog" class="font-mono text-sm text-ink-dim hover:text-accent transition-colors">← 返回博客</a>

      <header class="mt-6 mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight">{title}</h1>
        <div class="mt-4 flex flex-wrap items-center gap-3 text-sm">
          <time class="font-mono text-ink-faint">{fmt(date)}</time>
          <span class="font-mono text-ink-faint">· 约 {readMins} 分钟</span>
          <a href={`/categories/${category}`} class="font-mono text-xs text-accent bg-accent/10 border border-accent/30 rounded px-2 py-0.5 hover:bg-accent/20 transition-colors">{category}</a>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {tags.map((t) => (
                <a href={`/tags/${t}`} class="font-mono text-xs text-accent/80 bg-accent/5 border border-accent/20 rounded px-2 py-0.5 hover:bg-accent/10 transition-colors">#{t}</a>
              ))}
            </div>
          )}
        </div>
      </header>

      <hr class="border-line mb-8" />

      <div class="prose-tech">
        <Content />
      </div>

      <!-- 上一篇 / 下一篇 -->
      <nav class="mt-16 grid gap-4 sm:grid-cols-2">
        {newer ? (
          <a href={postUrl(newer)} class="card p-4 group">
            <p class="font-mono text-xs text-ink-faint mb-1">← 上一篇</p>
            <p class="text-ink group-hover:text-accent transition-colors text-sm">{newer.data.title}</p>
          </a>
        ) : <div></div>}
        {older && (
          <a href={postUrl(older)} class="card p-4 group text-right">
            <p class="font-mono text-xs text-ink-faint mb-1">下一篇 →</p>
            <p class="text-ink group-hover:text-accent transition-colors text-sm">{older.data.title}</p>
          </a>
        )}
      </nav>

      <Comments />
    </article>

    <!-- 目录 -->
    {toc.length > 0 && (
      <aside class="hidden lg:block w-56 shrink-0">
        <div class="sticky top-24">
          <p class="font-mono text-xs text-ink-faint mb-3">目录</p>
          <ul class="space-y-2 text-sm border-l border-line">
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'pl-6' : 'pl-3'}>
                <a href={`#${h.slug}`} class="text-ink-dim hover:text-accent transition-colors block leading-snug">{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
